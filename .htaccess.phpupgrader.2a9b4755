<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Allow access to existing files or folders
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Send everything else to laravel/public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
